<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.LoginController"
      style="-fx-background-color: #f4f4f4;">
    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

    <Label text="Racing Login" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <TextField fx:id="usernameField" promptText="Username" maxWidth="250"/>
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="250"/>

    <Button text="Login" onAction="#handleLogin"
            maxWidth="250"
            style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>
</VBox>
