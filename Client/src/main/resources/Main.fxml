<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.MainController"
      style="-fx-background-color: #f9f9f9;">
    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label fx:id="angajatLabel" text="Racing Management" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Logout" onAction="#handleLogout"
                style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-cursor: hand;"/>
    </HBox>

    <Separator/>

    <Label text="Curse disponibile (Selectati o cursa de aici pentru a inscrie):" style="-fx-font-weight: bold;"/>
    <TableView fx:id="curseTable" prefHeight="180">
        <columns>
            <TableColumn fx:id="colCapacitate" text="Capacitate Motor" prefWidth="200"/>
            <TableColumn fx:id="colNrParticipanti" text="Nr. Participanti" prefWidth="150"/>
        </columns>
    </TableView>

    <Separator/>

    <Label text="Cauta participanti dupa echipa:" style="-fx-font-weight: bold;"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="cautareEchipaField" promptText="ex: Suzuki, Honda..." prefWidth="250"/>
        <Button text="Cauta" onAction="#handleCautare"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;"/>
    </HBox>
    <TableView fx:id="participantiTable" prefHeight="150">
        <columns>
            <TableColumn fx:id="colPartNume" text="Nume" prefWidth="200"/>
            <TableColumn fx:id="colPartCapacitate" text="ID Cursa" prefWidth="100"/>
            <TableColumn fx:id="colPartEchipa" text="Echipa" prefWidth="150"/>
        </columns>
    </TableView>

    <Separator/>

    <Label text="Inscrie participant (la cursa selectata sus):" style="-fx-font-weight: bold;"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="numeField" promptText="Nume" prefWidth="150"/>
        <TextField fx:id="cnpField" promptText="CNP" prefWidth="130"/>
        <TextField fx:id="echipaField" promptText="Echipa" prefWidth="100"/>
        <Button text="Inscrie" onAction="#handleInscriere"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-cursor: hand;"/>
    </HBox>

    <Separator/>

    <Label text="Modifica echipa participant (selectati participantul in tabelul de cautare):" style="-fx-font-weight: bold;"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="echipaNouaField" promptText="Noua echipa" prefWidth="150"/>
        <Button text="Modifica" onAction="#handleModificareEchipa"
                style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-cursor: hand;"/>
    </HBox>

    <Label fx:id="statusLabel" style="-fx-text-fill: green;"/>
</VBox>